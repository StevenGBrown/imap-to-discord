{
  "name": "imap-to-discord",
  "version": "0.1.0",
  "description": "AWS Lambda that retrieves emails from an IMAP mailbox and sends them to Discord",
  "keywords": [
    "aws",
    "email",
    "imap",
    "discord"
  ],
  "license": "MIT",
  "author": {
    "name": "Steven Brown",
    "email": "StevenGBrown@gmail.com"
  },
  "type": "module",
  "main": "lib/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/StevenGBrown/imap-to-discord.git"
  },
  "scripts": {
    "build": "npm ci --no-audit --no-fund",
    "bootstrap": "node --run build && npx cdk bootstrap",
    "deploy": "node --run check && npx cdk deploy",
    "check": "node --run build && npx run-s \"check:**\"",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint . --max-warnings 0",
    "check:cdk": "CONFIG_FILE=arn:aws:s3:::bucket/key cdk synth",
    "start": "tsx bin/start.ts",
    "update-deps": "npm-check-updates --upgrade --peer --install never && del-cli package-lock.json && npm install"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.997.0",
    "@aws-sdk/client-s3": "3.997.0",
    "@aws-sdk/lib-dynamodb": "3.997.0",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "discord.js": "14.26.0",
    "escape-string-regexp": "4.0.0",
    "get-stream": "6.0.1",
    "imapflow": "1.3.1",
    "mailparser": "3.9.8",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/js": "9.39.3",
    "@types/aws-lambda": "8.10.84",
    "@types/imapflow": "1.0.15",
    "@types/mailparser": "3.4.0",
    "@types/node": "24.11.0",
    "@types/ws": "8.2.1",
    "aws-cdk": "2.1117.0",
    "del-cli": "7.0.0",
    "esbuild": "0.25.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-security": "4.0.0",
    "npm-check-updates": "19.6.6",
    "npm-run-all2": "8.0.4",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=7"
  }
}
